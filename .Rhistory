dataset <- inner_join(house_price, economics_factors_quarterly, by = "DATE") %>%
dplyr::select(-observation_date) %>%
mutate(DATE = as.Date(DATE), time_index = seq_len(n()))
data_scaled <- dataset %>%
na.omit() %>%
mutate(
MSPUS             = as.numeric(scale(MSPUS)),
time_index        = as.numeric(scale(time_index)),
GDP               = as.numeric(scale(GDP)),
unemployment_rate = as.numeric(scale(unemployment_rate)),
