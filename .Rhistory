plot(x=dataset$DATE, y=dataset$MSPUS,
ylab="Median US House Price",
xlab="Date", type="l")
# Predictions
diff_log_y = diff(log(dataset$MSPUS))
diff_y = diff(dataset$MSPUS)
diff_y_scaled = diff(data_scaled$MSPUS)
plot(diff_y, type="l")
# Find best ARIMA model based on AIC
arima_best_fit = auto.arima(diff_y)
arima_1_1 = arima(diff_y, order=c(1, 1, 1))
# mu, ar1, ma1, ma2 parameters
summary(arima_best_fit)
# mu, ar1, ma1 parameters
summary(arima_1_1)
# Approximately Normal Residuals
# MA(3) Model
qqnorm(arima_best_fit$residuals, main="MA(3)")
qqline(arima_best_fit$residuals)
# ARIMA(1, 1) Model
qqnorm(arima_1_1$residuals, main="ARMA(1, 1)")
qqline(arima_1_1$residuals)
train_data=list(
N = length(diff_y_scaled),
y = diff_y_scaled
)
n_samples = 10000
ma3_mod <- cmdstan_model("source/ma3.stan");
# arma11_mod <- cmdstan_model("source/arima.stan");
ma3_fit <- ma3_mod$sample(
seed=2026,
chains=2,
refresh=n_samples,
iter_warmup=2500, # Ensures that chain is sufficiently burned-in
iter_sampling=n_samples,
data=train_data,
show_exceptions=FALSE
)
head(ma3_fit$summary())
# Samples
posterior_samples <- ma3_fit$draws(variables=c("mu", "eps[5]", "sigma"))
# Trace Plots
mcmc_trace(posterior_samples, facet_args=list(ncol=1)) + theme_minimal()
# Rank Plots
mcmc_rank_hist(posterior_samples) + theme_minimal()
# Checking Posterior Predictive Samples against Observed
y_preds_MCMC <- ma3_fit$draws(c("y_post_pred"), format="draws_matrix")
pp_check(diff_y_scaled, y_preds_MCMC[400:600, ], fun="dens_overlay")
ma3_mod_cv <- cmdstan_model("source/ma3_cross_val.stan")
# Leave One out Method for 80% Credible Interval
# t_lower >= 4
# t_upper <= N
ci_ma3_cv <- function(mod, data, n_samples, lower_t, upper_t) {
ci_lower = c()
ci_upper = c()
for (t in lower_t:upper_t) {
train_data = list(
N = length(data[-t]),
y = data[-t],
t_pred = t
)
mod_fit <- mod$sample(
chains=1,
iter_warmup = 2500,
refresh = n_samples ,
iter_sampling = n_samples,
data=train_data,
show_messages=FALSE,
show_exceptions = FALSE)
y_pred_samples <- as.vector(
mod_fit$draws(variables=c("y_pred"),
format="matrix")
)
ci = quantile(y_pred_samples, c(0.1, 0.9))
ci_lower = c(ci_lower, ci["10%"])
ci_upper = c(ci_upper, ci["90%"])
print(paste("Done CI for time:", t))
}
return(data.frame(ci_lower, ci_upper))
}
l_t = 5
u_t = 79
ci_ma3 <- ci_ma3_cv(ma3_mod_cv, diff_y_scaled, n_samples=5000, lower_t=l_t, upper_t=u_t)
# ============================================================
# MA(3) Model - Variational Inference (VI)
# ============================================================
library(cmdstanr)
library(bayesplot)
library(dplyr)
library(lubridate)
library(ggplot2)
# ── 1. Load & Prepare Data ──────────────────────────────────
house_price <- read.csv(
"https://raw.githubusercontent.com/yun-sky/STAT-405-Project/refs/heads/master/Datasets/MSPUS.csv",
header = TRUE
)
economic_factors <- read.csv(
"https://raw.githubusercontent.com/yun-sky/STAT-405-Project/refs/heads/master/Datasets/US_House_Price.csv",
header = TRUE
)
economics_factors_quarterly <- economic_factors %>%
mutate(
DATE    = as.Date(DATE),
quarter = floor_date(DATE, unit = "quarter")
) %>%
group_by(quarter) %>%
summarise(
GDP               = mean(GDP,               na.rm = TRUE),
mortgage_rate     = mean(mortgage_rate,     na.rm = TRUE),
unemployment_rate = mean(unemployment_rate, na.rm = TRUE),
.groups = "drop"
) %>%
rename(DATE = quarter)
house_price <- house_price %>%
mutate(DATE = as.Date(observation_date))
dataset <- inner_join(house_price, economics_factors_quarterly, by = "DATE") %>%
dplyr::select(-observation_date) %>%
mutate(DATE = as.Date(DATE), time_index = seq_len(n()))
data_scaled <- dataset %>%
na.omit() %>%
mutate(
MSPUS             = as.numeric(scale(MSPUS)),
time_index        = as.numeric(scale(time_index)),
GDP               = as.numeric(scale(GDP)),
unemployment_rate = as.numeric(scale(unemployment_rate)),
mortgage_rate     = as.numeric(scale(mortgage_rate))
)
diff_y_scaled <- diff(data_scaled$MSPUS)
# ── 2. Prepare Stan Data ─────────────────────────────────────
train_data <- list(
N = length(diff_y_scaled),
y = diff_y_scaled
)
# ── 3. Compile MA(3) Stan Model ──────────────────────────────
# Point this to wherever your ma3.stan file lives
ma3_mod <- cmdstan_model("source/ma3.stan")
# ── 4. Run Variational Inference ─────────────────────────────
ma3_vi <- ma3_mod$variational(
data            = train_data,
seed            = 405,
algorithm       = "meanfield",   # "meanfield" (faster) or "fullrank" (richer)
iter            = 10000,         # max VI iterations
tol_rel_obj     = 0.001,         # convergence tolerance
draws           = 10000,         # posterior draws to sample from the approximation
output_samples  = 10000
)
# ── 5. Summary Table (mirrors MCMC summary) ──────────────────
params_of_interest <- c("mu", "theta[1]", "theta[2]", "theta[3]", "sigma")
vi_summary <- ma3_vi$summary(variables = params_of_interest) %>%
dplyr::select(variable, mean, median, sd, mad, q5, q95)
cat("\n## VI Diagnostics\n")
cat("### Summary\n")
print(vi_summary)
