library(cmdstanr)
library(bayesplot)
library(dplyr)
library(lubridate)
library(ggplot2)
# ── 1. Load & Prepare Data ──────────────────────────────────
house_price <- read.csv(
"https://raw.githubusercontent.com/yun-sky/STAT-405-Project/refs/heads/master/Datasets/MSPUS.csv",
header = TRUE
)
economic_factors <- read.csv(
"https://raw.githubusercontent.com/yun-sky/STAT-405-Project/refs/heads/master/Datasets/US_House_Price.csv",
header = TRUE
)
economics_factors_quarterly <- economic_factors %>%
mutate(
DATE    = as.Date(DATE),
quarter = floor_date(DATE, unit = "quarter")
) %>%
group_by(quarter) %>%
summarise(
GDP               = mean(GDP,               na.rm = TRUE),
mortgage_rate     = mean(mortgage_rate,     na.rm = TRUE),
unemployment_rate = mean(unemployment_rate, na.rm = TRUE),
.groups = "drop"
) %>%
rename(DATE = quarter)
house_price <- house_price %>%
mutate(DATE = as.Date(observation_date))
dataset <- inner_join(house_price, economics_factors_quarterly, by = "DATE") %>%
dplyr::select(-observation_date) %>%
mutate(DATE = as.Date(DATE), time_index = seq_len(n()))
data_scaled <- dataset %>%
na.omit() %>%
mutate(
MSPUS             = as.numeric(scale(MSPUS)),
time_index        = as.numeric(scale(time_index)),
GDP               = as.numeric(scale(GDP)),
unemployment_rate = as.numeric(scale(unemployment_rate)),
mortgage_rate     = as.numeric(scale(mortgage_rate))
)
diff_y_scaled <- diff(data_scaled$MSPUS)
# ── 2. Prepare Stan Data ─────────────────────────────────────
train_data <- list(
N = length(diff_y_scaled),
y = diff_y_scaled
)
# ── 3. Compile MA(3) Stan Model ──────────────────────────────
# Point this to wherever your ma3.stan file lives
ma3_mod <- cmdstan_model("source/ma3.stan")
# ── 4. Run Variational Inference ─────────────────────────────
ma3_vi <- ma3_mod$variational(
data           = train_data,
seed           = 2026,
algorithm      = "fullrank",
iter           = 50000,
tol_rel_obj    = 0.001,
draws          = 10000,
output_samples = 10000,
elbo_samples   = 500,   # default is 100 — more samples = smoother ELBO estimate
grad_samples   = 5      # default is 1   — reduces gradient noise too
)
# ── 5. Summary Table (mirrors MCMC summary) ──────────────────
params_of_interest <- c("mu", "theta[1]", "theta[2]", "theta[3]", "sigma")
vi_summary <- ma3_vi$summary(variables = params_of_interest) %>%
dplyr::select(variable, mean, median, sd, mad, q5, q95)
cat("\n## VI Diagnostics\n")
cat("### Summary\n")
print(vi_summary)
